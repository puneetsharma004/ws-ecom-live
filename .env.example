# Copy to .env.local and fill in. Never commit .env.local.

# --- Supabase ---
# Project URL and anon (public) key are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key bypasses RLS. SERVER ONLY. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY= 

# --- Razorpay ---
# Key id is public (used by Razorpay Checkout in the browser).
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_T2wvtRPcBrqAmY
# Secret + webhook secret are SERVER ONLY.
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- App ---
# Public base URL of the site (used for redirects / absolute links).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Where the "Courses" showcase links out to (your main learning platform).
NEXT_PUBLIC_COURSES_URL=https://www.wscubetech.com
